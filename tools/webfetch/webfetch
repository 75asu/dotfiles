#!/usr/bin/env bash
# Launcher: resolve this script's real dir (following the ~/.local/bin symlink),
# then run the Node CLI from the tool's own directory (so node_modules is found).
set -euo pipefail
src="${BASH_SOURCE[0]}"
while [ -h "$src" ]; do
  dir="$(cd -P "$(dirname "$src")" >/dev/null 2>&1 && pwd)"
  src="$(readlink "$src")"
  [[ $src != /* ]] && src="$dir/$src"
done
dir="$(cd -P "$(dirname "$src")" >/dev/null 2>&1 && pwd)"
exec node "$dir/webfetch.mjs" "$@"
