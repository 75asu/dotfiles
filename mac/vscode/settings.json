{
    "workbench.colorTheme": "Tokyo Night",
    "window.menuBarVisibility": "classic",
    "workbench.iconTheme": "Monokai Pro (Filter Octagon) Icons",
    "tabnine.experimentalAutoImports": true,
    "editor.fontFamily": "JetBrains Mono, 'Courier New', monospace",
    "editor.fontLigatures": true,
    "editor.lineHeight": 1.8,
    "editor.cursorBlinking": "smooth",
    "editor.cursorSmoothCaretAnimation": "on",
    "editor.smoothScrolling": true,
    "editor.bracketPairColorization.enabled": true,
    "editor.guides.bracketPairs": true,
    "editor.renderLineHighlight": "all",
    "workbench.tree.indent": 16,
    "editor.padding.top": 8,
    "workbench.startupEditor": "none",
    "redhat.telemetry.enabled": false,
    "editor.minimap.enabled": false,
    "gopls": {},
    "go.toolsEnvVars": {
        "GOOS": "linux",
        "GOARCH": "amd64"
    },
    "go.goroot": "/opt/homebrew/Cellar/go/1.26.3/libexec",
    "terminal.integrated.env.osx": {
        "PATH": "/opt/homebrew/bin:/opt/homebrew/sbin:${env:PATH}"
    },
    "git.alwaysSignOff": true,
    "go.toolsManagement.autoUpdate": true,
    "terminal.integrated.defaultProfile.windows": "Git Bash",
    "files.autoSave": "afterDelay",
    "liveServer.settings.donotShowInfoMsg": true,
    "editor.fontSize": 15,
    "terminal.integrated.fontSize": 15,
    "terminal.integrated.fontFamily": "JetBrains Mono, Menlo, monospace",
    "terminal.integrated.gpuAcceleration": "canvas",
    "makefile.configureOnOpen": true,
    "sqltools.formatLanguages": [
        "sql"
    ],
    "[sql]": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "mtxr.sqltools"
    },
    "window.zoomLevel": 0.5,
    "workbench.colorCustomizations": {
        "panel.border": "#3d59a1",
        "sideBar.border": "#3d59a1",
        "activityBar.border": "#3d59a1",
        "editorGroup.border": "#3d59a1",
        "terminal.background": "#0d0f1a",
        "panel.background": "#0d0f1a",
        "sideBar.foreground": "#c0caf5",
        "sideBarTitle.foreground": "#7aa2f7",
        "list.activeSelectionForeground": "#ffffff",
        "list.activeSelectionBackground": "#283457",
        "list.inactiveSelectionForeground": "#a9b1d6",
        "list.hoverForeground": "#c0caf5",
        "list.hoverBackground": "#1a1b2e"
    },
    "terminal.integrated.mouseWheelScrollSensitivity": 3
}
